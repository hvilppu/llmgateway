flowchart TD
    Client([Käyttäjä / HTTP-client])

    subgraph GW["Azure App Service — LlmGateway (.NET 10)"]
        MW1[HTTPS Redirection]
        MW2["ApiKeyMiddleware\nX-Api-Key → 401 jos puuttuu"]
        EP["ChatEndpoints\nPOST /api/chat → ChatResponse\nPOST /api/chat/stream → SSE"]
        RE["RoutingEngine\nResolveModelChain · IsToolsEnabled\nIsRagEnabled · GetQueryBackend"]
        CB["InMemoryCircuitBreaker\nper-model: Closed → Open → Half-Open"]
        OAI["AzureOpenAIClient\nRetry max 2 · Timeout 15 s"]

        subgraph SP["Yksinkertainen polku — ToolsEnabled=false"]
            SC["GetChatCompletionAsync\nFallback-ketju mallien välillä"]
        end

        subgraph RP["RAG-polku — RagEnabled=true"]
            EMB["GetEmbeddingAsync\nteksti → float32[1536]"]
            RGS["CosmosRagService\nVectorDistance → top-3 kuukausiraportti"]
        end

        subgraph AL["Agenttiloop — ToolsEnabled=true · max 5 kierrosta"]
            RC["GetRawCompletionAsync\n+ tool definitions"]
            FIN{finish_reason?}
            CQS["CosmosQueryService\n+ CosmosSchemaProvider\ndynaaminen skeema, 60 min"]
            SQS["SqlQueryService\n+ SqlSchemaProvider\ndynaaminen skeema, 60 min"]
        end
    end

    AzOAI[("Azure OpenAI\nGPT-4 · GPT-4o-mini")]
    AzEMB[("Azure OpenAI\ntext-embedding-3-small")]
    CosmDB[("Cosmos DB\nragdb / documents")]
    KuuDB[("Cosmos DB\nragdb / kuukausiraportit\nvektori-indeksi")]
    SqlDB[("Azure SQL\ntaulu: mittaukset")]

    Client -->|"POST /api/chat\nPOST /api/chat/stream"| MW1
    MW1 --> MW2
    MW2 -->|"401 Unauthorized"| Client
    MW2 --> EP
    EP --> RE
    RE -->|"ToolsEnabled=false"| SC
    RE -->|"RagEnabled=true"| EMB
    RE -->|"ToolsEnabled=true\nRagEnabled=false"| RC
    SC --> OAI
    EMB -->|"HTTP POST"| AzEMB
    AzEMB -->|"float32[1536]"| RGS
    RGS -->|"VectorDistance SELECT"| KuuDB
    KuuDB -->|"top-3 kuvaukset"| RGS
    RGS -->|"RAG-konteksti + skeema\n→ agenttiloop"| RC
    RC --> OAI
    OAI <-->|"IsOpen · RecordFailure · RecordSuccess"| CB
    OAI -->|"HTTP POST"| AzOAI
    AzOAI --> OAI
    RC --> FIN
    FIN -->|stop| EP
    FIN -->|"tool_calls · backend=cosmos"| CQS
    FIN -->|"tool_calls · backend=mssql"| SQS
    CQS -->|"Cosmos SQL SELECT"| CosmDB
    CosmDB -->|JSON| CQS
    SQS -->|"T-SQL SELECT"| SqlDB
    SqlDB -->|JSON| SQS
    CQS -->|"JSON tulokset → loop"| RC
    SQS -->|"JSON tulokset → loop"| RC
    EP -->|"200 / 503 / 502 / 500\nSSE text/event-stream"| Client

    subgraph SF["Azure Functions — SyncFunction"]
        TRG["CosmosToSqlTrigger\nTimer 15 min"]
        CSS["CosmosSyncService\nCosmos → MS SQL (MERGE INTO)"]
        MRS["MonthlyReportService\nGPT-4o-mini kuvaus + embedding\n→ kuukausiraportit"]
        RBS["ReportBackfillService\nIHostedService — historiadatan backfill käynnistyksessä"]
        MGS["MigrationService\nIHostedService — SQL-taulujen luonti käynnistyksessä"]
    end

    TRG --> CSS
    TRG --> MRS
    RBS --> MRS
    CSS -->|"Cosmos SQL SELECT"| CosmDB
    CSS -->|"T-SQL MERGE INTO"| SqlDB
    MRS -->|"SELECT * documents"| CosmDB
    MRS -->|"upsert kuukausiraportti"| KuuDB
    MRS -->|"embedding"| AzEMB
    MRS -->|"GPT-4o-mini kuvaus"| AzOAI

